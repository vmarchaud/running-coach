{
  "name": "running-coach",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "src/worker.ts",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nightly-agents-running-coach",
      "database_id": "df9d6e72-54ad-4013-aae0-f3b9e748b36d"
    }
  ]
}
