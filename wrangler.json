{
  "name": "running-coach",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "src/worker.ts",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nightly-agents-running-coach",
      "database_id": "c9ad89b6-572b-43d8-8547-383e69a5f3d8"
    }
  ],
  "triggers": {
    "crons": ["0 8 * * *"]
  }
}
